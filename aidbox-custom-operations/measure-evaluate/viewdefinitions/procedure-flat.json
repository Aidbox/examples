{
  "resourceType": "ViewDefinition",
  "id": "procedure-flat",
  "url": "https://health-samurai.io/fhir/ViewDefinition/procedure-flat",
  "name": "procedure_flat",
  "status": "active",
  "resource": "Procedure",
  "select": [
    {
      "column": [
        {
          "name": "id",
          "path": "getResourceKey()"
        },
        {
          "name": "patient_id",
          "path": "subject.getReferenceKey(Patient)"
        },
        {
          "name": "status",
          "path": "status"
        },
        {
          "name": "performed_start",
          "path": "performed.ofType(dateTime)"
        },
        {
          "name": "performed_period_start",
          "path": "performed.ofType(Period).start"
        },
        {
          "name": "performed_period_end",
          "path": "performed.ofType(Period).end"
        },
        {
          "name": "has_outcome",
          "path": "outcome.exists()"
        }
      ]
    },
    {
      "column": [
        {
          "name": "code_system",
          "path": "system"
        },
        {
          "name": "code",
          "path": "code"
        },
        {
          "name": "display",
          "path": "display"
        }
      ],
      "forEachOrNull": "code.coding"
    }
  ]
}
