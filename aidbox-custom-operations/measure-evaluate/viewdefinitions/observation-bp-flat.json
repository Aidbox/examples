{
  "resourceType": "ViewDefinition",
  "id": "observation-bp-flat",
  "name": "observation_bp_flat",
  "status": "active",
  "resource": "Observation",
  "where": [
    {"path": "code.coding.where(code = '85354-9').exists()"}
  ],
  "select": [
    {
      "column": [
        {"name": "id", "path": "getResourceKey()"},
        {"name": "patient_id", "path": "subject.getReferenceKey(Patient)"},
        {"name": "status", "path": "status"},
        {"name": "effective_dt", "path": "effective.ofType(dateTime)"},
        {"name": "effective_period_start", "path": "effective.ofType(Period).start"},
        {"name": "encounter_id", "path": "encounter.getReferenceKey(Encounter)"},
        {
          "name": "systolic",
          "description": "Systolic BP component (LOINC 8480-6)",
          "path": "component.where(code.coding.where(code = '8480-6').exists()).value.ofType(Quantity).value"
        },
        {
          "name": "diastolic",
          "description": "Diastolic BP component (LOINC 8462-4)",
          "path": "component.where(code.coding.where(code = '8462-4').exists()).value.ofType(Quantity).value"
        }
      ]
    }
  ]
}
