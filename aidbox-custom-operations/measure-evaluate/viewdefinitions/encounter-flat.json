{
  "resourceType": "ViewDefinition",
  "id": "encounter-flat",
  "url": "https://health-samurai.io/fhir/ViewDefinition/encounter-flat",
  "name": "encounter_flat",
  "status": "active",
  "resource": "Encounter",
  "select": [
    {
      "column": [
        {
          "name": "id",
          "path": "getResourceKey()"
        },
        {
          "name": "patient_id",
          "path": "subject.getReferenceKey(Patient)"
        },
        {
          "name": "status",
          "path": "status"
        },
        {
          "name": "period_start",
          "path": "period.start"
        },
        {
          "name": "period_end",
          "path": "period.end"
        },
        {
          "name": "class_code",
          "description": "Encounter.class.code \u2014 used by CMS165 for inpatient/ED filtering (EMER, IMP, ACUTE, etc.)",
          "path": "class.code"
        },
        {
          "name": "discharge_code",
          "description": "Encounter.hospitalization.dischargeDisposition \u2014 used by shared_hospice",
          "path": "hospitalization.dischargeDisposition.coding.first().code"
        }
      ]
    },
    {
      "column": [
        {
          "name": "type_system",
          "path": "system"
        },
        {
          "name": "type_code",
          "path": "code"
        },
        {
          "name": "type_display",
          "path": "display"
        }
      ],
      "forEachOrNull": "type.coding"
    }
  ]
}
