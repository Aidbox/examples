    },
    {
      "name": "period_end",
      "use": "in",
      "type": "date"
    }
  ],
  "relatedArtifact": [
    {
      "type": "depends-on",
      "resource": "https://health-samurai.io/fhir/ViewDefinition/concept",
      "label": "vd_concept"
    },
    {
      "type": "depends-on",
      "resource": "https://health-samurai.io/fhir/ViewDefinition/condition-flat",
      "label": "vd_condition_flat"
